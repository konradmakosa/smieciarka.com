{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*\\.(jpg|jpeg|png|gif|ico|svg))",
      "dest": "/public/$1"
    },
    {
      "src": "/ical/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/adres/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/sitemap.xml",
      "dest": "api/index.py"
    },
    {
      "src": "/robots.txt",
      "dest": "api/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
